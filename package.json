{
  "name": "@lohnica/n8n-nodes-lohnica",
  "version": "0.1.0",
  "description": "n8n node for the Lohnica German payroll API: gross-to-net, net-to-gross and cost-to-net calculations plus health insurance lookup",
  "license": "MIT",
  "homepage": "https://brutto-netto-api.de",
  "keywords": ["n8n-community-node-package", "n8n", "lohnica", "payroll", "lohn", "brutto-netto", "germany"],
  "author": { "name": "M. Kreis", "email": "mail@mariuskreis.de" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lohnica/n8n-nodes-lohnica.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": ["dist/credentials/LohnicaApi.credentials.js"],
    "nodes": ["dist/nodes/Lohnica/Lohnica.node.js"]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": { "n8n-workflow": "*" }
}
